PORT=3000
DATA_DIR=/data
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
# Long random string used to sign member session cookies. If missing, the
# server auto-generates one at /data/session.secret on first boot, but every
# rebuild that ships without a persistent /data volume would invalidate logins.
# Generate with: openssl rand -hex 48
SESSION_SECRET=change-me-to-a-long-random-string
